{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile photo."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the user was created."
        }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "A digital product for sale.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the product (e.g., 'bundle')."
        },
        "title": {
          "type": "string",
          "description": "The display name of the product."
        },
        "downloadUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL to download the digital product."
        },
        "downloadUrl2": {
          "type": "string",
          "format": "uri",
          "description": "An optional second URL for the digital product."
        },
        "emailSubject": {
          "type": "string",
          "description": "The subject line of the delivery email."
        },
        "emailBody": {
          "type": "string",
          "description": "The body text of the delivery email (supports placeholders)."
        }
      },
      "required": ["id", "title", "downloadUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user profile document."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "The digital product configuration."
    }
  }
}
